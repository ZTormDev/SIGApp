{
  "expo": {
    "name": "SIGApp",
    "slug": "SIGApp",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/sigapp-icons/appstore.png",
    "scheme": "sigapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ztormdev.sigapp",
      "icon": "./assets/images/sigapp-icons/appstore.png"
    },
    "android": {
      "package": "com.ztormdev.sigapp",
      "icon": "./assets/images/sigapp-icons/playstore.png",
      "predictiveBackGestureEnabled": false,
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/sigapp-icons/playstore.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/sigapp-icons/playstore.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/sigapp-icons/android/mipmap-xxxhdpi/sigapp.png",
          "color": "#7C4DFF"
        }
      ],
      "@react-native-firebase/app"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7b000d0a-b7c1-41c6-99be-878d91e796e9"
      }
    }
  }
}
