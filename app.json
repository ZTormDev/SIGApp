{
  "expo": {
    "name": "SIGApp",
    "slug": "SIGApp",
    "version": "1.0.0",
    "owner": "ZTormDev",
    "orientation": "portrait",
    "icon": "./assets/images/sigapp-icons/appstore.png",
    "scheme": "sigapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ztormdev.sigapp",
      "icon": "./assets/images/sigapp-icons/appstore.png"
    },
    "android": {
      "package": "com.ztormdev.sigapp",
      "versionCode": 1,
      "icon": "./assets/images/sigapp-icons/playstore.png",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/sigapp-icons/playstore.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}